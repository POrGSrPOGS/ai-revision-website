{
  "name": "node-baseplate",
  "version": "1.0.0",
  "description": "Scalable Node.js web application baseplate",
  "main": "server.js",
  "scripts": {
    "start": "npm run build --prefix client && node server.js",
    "server": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"npm run dev --prefix client\"",
    "dev:server": "nodemon server.js",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^9.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
